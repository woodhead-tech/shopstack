# Copy to .env and fill in values before running docker compose up
# Generate passwords: openssl rand -hex 16

# Nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASS=changeme
NEXTCLOUD_DB_PASS=changeme

# Invoice Ninja
# Generate: echo "base64:$(openssl rand -base64 32)"
INVOICENINJA_APP_KEY=base64:changeme
INVOICENINJA_DB_PASS=changeme

# WooCommerce
WP_ADMIN_USER=admin
WP_ADMIN_PASS=changeme
WP_ADMIN_EMAIL=brandon@woodhead.tech
WP_SITE_TITLE=ShopStack Dev Store
WOOCOMMERCE_DB_PASS=changeme
