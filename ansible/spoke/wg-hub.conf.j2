# wg-hub.conf - ShopStack management spoke config
# Generated by spoke/playbook.yml -- do not edit manually.
#
# This interface connects the ShopStack box back to Brandon's management hub
# so he can SSH in for support, patching, and monitoring without a public SSH port.

[Interface]
Address = {{ wg_spoke_ip }}/24
PrivateKey = {{ wg_spoke_private_key }}

[Peer]
# ShopStack management hub (wg1 @ 192.168.86.39)
PublicKey = {{ wg_hub_public_key }}
PresharedKey = {{ wg_spoke_preshared_key }}
Endpoint = wg.woodhead.tech:51821
AllowedIPs = 10.99.0.0/24
PersistentKeepalive = 25
