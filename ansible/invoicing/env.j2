APP_NAME="Invoice Ninja"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://billing.{{ domain }}
APP_KEY={{ invoiceninja_app_key }}

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=invoiceninja-db
DB_PORT=3306
DB_DATABASE={{ invoiceninja_db_name }}
DB_USERNAME={{ invoiceninja_db_user }}
DB_PASSWORD={{ invoiceninja_db_pass }}

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=invoiceninja-redis
REDIS_PORT=6379

REQUIRE_HTTPS=true
TRUSTED_PROXIES=*

# Mail — configure after deploy in Settings → Email Settings
# Uses Mailcow if deployed on the same server
MAIL_MAILER=smtp
MAIL_HOST=mail.{{ domain }}
MAIL_PORT=587
MAIL_ENCRYPTION=tls
# MAIL_USERNAME=invoices@{{ domain }}
# MAIL_PASSWORD=your-mailcow-password
MAIL_FROM_ADDRESS=invoices@{{ domain }}
MAIL_FROM_NAME="{% raw %}{{ env('APP_NAME') }}{% endraw %}"

# Stripe keys — add via the UI: Settings → Payment Gateways
# These env vars are optional pre-seeds if you want to automate setup
# STRIPE_KEY=pk_live_...
# STRIPE_SECRET=sk_live_...
