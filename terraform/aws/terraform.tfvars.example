aws_region    = "us-east-1"
client_name   = "vetclinic-oak"       # short slug, used for resource names
instance_type = "t3.large"
disk_size_gb  = 40
key_pair_name = "shopstack-key"       # must exist in your AWS account
subnet_id     = "subnet-xxxxxxxxx"    # public subnet in your default VPC

# Restrict SSH to your IP only — find yours at ifconfig.me
admin_cidr_blocks = ["YOUR.IP.HERE/32"]
